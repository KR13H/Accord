# Accord production environment template
# Copy to .env.production and fill values before deploy.

# Core URLs
BACKEND_PUBLIC_URL=https://api.accord.example
FRONTEND_PUBLIC_URL=https://app.accord.example

# Realtime + security
ACCORD_REDIS_URL=redis://redis:6379/0
ACCORD_BIOMETRIC_SECRET=replace-with-strong-random-secret
ACCORD_SSE_TOKEN_SECRET=replace-with-separate-strong-random-secret
ACCORD_SSE_TOKEN_TTL_SECONDS=3600

# Backend runtime
ACCORD_DEPLOYMENT_MODE=cloud
OLLAMA_HOST=http://host.docker.internal:11434
DATABASE_URL=sqlite:////app/ledger.db

# CORS
CORS_ALLOW_ORIGINS=https://app.accord.example
CORS_ALLOW_ORIGIN_REGEX=

# Optional SMTP
ACCORD_SMTP_HOST=
ACCORD_SMTP_PORT=587
ACCORD_SMTP_USERNAME=
ACCORD_SMTP_PASSWORD=
ACCORD_SMTP_FROM=no-reply@accord.example
ACCORD_SMTP_USE_TLS=true
