# Backend runtime target
# Use your Neon or managed PostgreSQL URL in production.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Storage backend: local or s3
ACCORD_STORAGE_BACKEND=local
ACCORD_S3_BUCKET=
ACCORD_S3_REGION=ap-south-1
ACCORD_S3_ENDPOINT_URL=
ACCORD_S3_PUBLIC_BASE_URL=

# Encrypted Postgres backups (base64url 32-byte key)
ACCORD_BACKUP_ENCRYPTION_KEY=

# Deployment mode: sovereign-local (M3 tunnel) or cloud
ACCORD_DEPLOYMENT_MODE=sovereign-local
BACKEND_PUBLIC_URL=http://localhost:8000
FRONTEND_PUBLIC_URL=http://localhost:5173

# Explicit frontend origins (comma-separated)
CORS_ALLOW_ORIGINS=https://accord-stark.vercel.app,http://localhost:5173,http://127.0.0.1:5173

# Optional regex to allow dynamic preview domains (e.g., Vercel previews)
CORS_ALLOW_ORIGIN_REGEX=^https://.*\.vercel\.app$

# Security secrets
ACCORD_BIOMETRIC_SECRET=replace-with-strong-secret
