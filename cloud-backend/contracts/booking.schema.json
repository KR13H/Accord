{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SalesBooking",
  "type": "object",
  "required": [
    "booking_id",
    "project_id",
    "spv_id",
    "customer_name",
    "unit_code",
    "total_consideration",
    "booking_date",
    "status"
  ],
  "properties": {
    "booking_id": {"type": "string", "minLength": 1, "maxLength": 64},
    "project_id": {"type": "string", "minLength": 1, "maxLength": 64},
    "spv_id": {"type": "string", "minLength": 1, "maxLength": 64},
    "customer_name": {"type": "string", "minLength": 1, "maxLength": 180},
    "unit_code": {"type": "string", "minLength": 1, "maxLength": 64},
    "total_consideration": {"type": "string", "pattern": "^-?[0-9]+(\\.[0-9]{1,4})?$"},
    "booking_date": {"type": "string", "format": "date"},
    "status": {"type": "string", "enum": ["ACTIVE", "CANCELLED", "COMPLETED"]}
  }
}
